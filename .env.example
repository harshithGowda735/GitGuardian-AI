# AI API Keys (provide at least one)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Provider preference (gemini or openai)
AI_PROVIDER=gemini

# ========== GitHub App Authentication (Multi-user / Recommended) ==========
# Go to https://github.com/settings/apps/new to create a GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ========== Personal Token Authentication (Single-user / Local only) ==========
GITHUB_TOKEN=

# ========== Optional: Manual PR targeting (PAT mode only) ==========
GITHUB_OWNER=
GITHUB_REPO=
PR_NUMBER=

# ========== Server Config ==========
PORT=3000
