{
  "name": "GitGuardian AI",
  "version": "1.0.0",
  "description": "Autonomous Git agent for code review and auto-fixing.",
  "triggers": {
    "on": ["pre-commit", "push"]
  },
  "modules": {
    "reviewer": {
      "enabled": true,
      "strictness": "high"
    },
    "fixer": {
      "enabled": true,
      "autoApply": false
    },
    "scorer": {
      "enabled": true
    }
  },
  "ignorePatterns": [
    "node_modules/**",
    ".git/**",
    "package-lock.json"
  ]
}
